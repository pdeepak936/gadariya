# APPLICATION
NODE_ENV=development
APP_NAME=GADARIYA
APP_URL=http://localhost:3000
APP_PORT=3000

# DATABASE
MONGODB_URI=mongodb://mongo:27017/gadariya
MONGODB_USER=root
MONGODB_PASSWORD=root123

# REDIS (for caching and sessions)
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OTP
OTP_EXPIRY=5m
OTP_MAX_ATTEMPTS=5

# CLOUDINARY (Image Storage)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# PAYMENT GATEWAYS
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# EMAIL
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@gadariya.com
SMTP_FROM_NAME=GADARIYA

# SMS & NOTIFICATIONS
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890

WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE=your_whatsapp_phone

# SHIPPING
SHIPROCKET_EMAIL=your_shiprocket_email
SHIPROCKET_PASSWORD=your_shiprocket_password
SHIPROCKET_API_KEY=your_shiprocket_api_key

# ADMIN
ADMIN_EMAIL=admin@gadariya.com
ADMIN_PASSWORD=admin123

# FRONTEND
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# ANALYTICS & TRACKING
GOOGLE_ANALYTICS_ID=
FACEBOOK_PIXEL_ID=
HOTJAR_SITE_ID=

# SERVER URLS
SERVER_URL=http://localhost:5000
ADMIN_URL=http://localhost:3001
CLIENT_URL=http://localhost:3000

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# LOGGING
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# AWS S3 (Optional, for file storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=gadariya-uploads
